# 复制为 .env 并填写；HelloAgentsLLM会自动读取这几个环境变量
# 任意OpenAI兼容接口都行（官方API/阿里云百炼MaaS/中转站……），换供应商只需要
# 改这几行，不用碰代码。模型建议选带视觉理解能力、且验证过支持function calling的，
# 比如阿里云百炼的qwen3-vl-plus
LLM_MODEL_ID=
# 可选：命中探索记忆里已知节点（screenshot()返回known_actions非空）时切换的
# 便宜纯文本模型，不需要视觉能力，用来省钱省时间；不填就一直用上面那个模型
LLM_MODEL_ID_ROUTINE=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT=60
