# 复制为 .env 并填写；HelloAgentsLLM会自动读取这几个环境变量
# 任意OpenAI兼容接口都行（官方API/阿里云百炼MaaS/中转站……），换供应商只需要
# 改这几行，不用碰代码。模型建议选带视觉理解能力、且验证过支持function calling的，
# 比如阿里云百炼的qwen3-vl-plus
LLM_MODEL_ID=
# 可选：命中探索记忆里已知节点（screenshot()返回known_actions非空）时切换的
# 便宜纯文本模型，不需要视觉能力，用来省钱省时间；不填就一直用上面那个模型
LLM_MODEL_ID_ROUTINE=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT=60

# 可选：一键拉起模拟器用。填了LDCONSOLE_PATH（雷电模拟器ldconsole.exe的路径，比如
# E:\leidian\LDPlayer14\ldconsole.exe）之后，agent_runner.py启动前会自动检查这个
# 实例有没有在跑，没跑就拉起，再等adb连上、系统开机完成，才继续往下走；不填就假设
# 你自己管理模拟器/用真机，agent_runner.py不碰这一步，直接照常连profile.yaml里的
# adb.address。目前只适配雷电模拟器，见core/emulator.py
LDCONSOLE_PATH=
LDPLAYER_INDEX=0
