# 新游戏接入模板：复制这份改名为profile.yaml，按需填写

game_id: your_game_id                 # 唯一标识，建议全小写英文
display_name: 你的游戏中文名
package_name: com.example.yourgame
resolution: [1280, 720]
language: zh_cn
ocr_model: zh_cn

adb:
  address: 127.0.0.1:5555
  # adb_path: ""                      # 留空则自动探测

# resource_path支持传列表，会依次叠加加载。OCR模型是通用资源，不用跟着游戏资源包重复拷贝，
# 建议放进assets/ocr_models/<language>/（没有就照games/无期迷途的样子建一份），
# 这里只放游戏专属的pipeline+image：
resource_path:
  - games/你的游戏/resource       # 没有现成MaaFramework资源包就整个字段留空字符串""
  - assets/ocr_models/zh_cn      # 换语言就换成对应的assets/ocr_models/<language>目录
interface_path: games/你的游戏/interface.json
sensitive_keywords_path: games/你的游戏/sensitive_keywords.yaml

exploration_goal_hint: >
  简单描述游戏类型和界面特点，用于注入探索Prompt模板，
  帮助LLM判断该优先关注哪些方向。

# 可选：自由探索模式下，本次至少发现min_new_nodes个新界面(is_novel=True)才允许
# LLM调用Finish收尾，不够就被core/agent/react_agent_vision.py拦回去继续探索，max_steps
# 仍是最终兜底。不写这个字段/写0就是原来的行为——LLM自己判断"探得差不多了"就会
# 主动结束，实测容易发现个位数新界面就喊停，图会很碎
# min_new_nodes: 30

# 可选：实时日志面板的地址，不写就用默认的127.0.0.1:8765
# dashboard:
#   host: 127.0.0.1
#   port: 8765
